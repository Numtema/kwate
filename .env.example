# Public InsForge browser client
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Server-only InsForge administration / webhook fulfillment
INSFORGE_API_BASE_URL=
INSFORGE_ADMIN_TOKEN=
INSFORGE_API_KEY=

# Public payment catalog configuration
NEXT_PUBLIC_STRIPE_ENVIRONMENT=test
NEXT_PUBLIC_STRIPE_PRICE_PASS30=
NEXT_PUBLIC_STRIPE_PRICE_PASS12=
NEXT_PUBLIC_STRIPE_PRICE_PRO=

# Server-only Stripe webhook fulfillment on Vercel
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Canonical application URL
APP_URL=http://localhost:3000

# Optional legacy AI configuration. Remove when unused.

# Guarded provisioning controls — never commit real values
DEPLOYMENT_TARGET=development
CONFIRM_INSFORGE_PROVISION=
CONFIRM_INSFORGE_TARGET_HOST=
CONFIRM_PRODUCTION_BACKUP=

# KWATE V7 real two-account production test (GitHub Environment secrets)
KWATE_TEST_USER_A_EMAIL=
KWATE_TEST_USER_A_PASSWORD=
KWATE_TEST_USER_B_EMAIL=
KWATE_TEST_USER_B_PASSWORD=
KWATE_TEST_KEEP_POST=false
CONFIRM_V7_PRODUCTION_TEST=

# KWATE V7 media orphan control
